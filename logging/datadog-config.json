{
  "service": "secondbrain-os",
  "env": "production",
  "api_key_env": "DD_API_KEY",
  "logs_config": {
    "source": "python",
    "service_mapping": {
      "api": "secondbrain-api",
      "scheduler": "secondbrain-scheduler",
      "web": "secondbrain-web"
    }
  },
  "integrations": {
