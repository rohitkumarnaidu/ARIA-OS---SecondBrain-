# =============================================================================
# Second Brain OS — Environment Variables (Enterprise Template v6)
# =============================================================================
# Copy to .env.local (frontend) and configure in Railway/Vercel (production)
#   cp .env.example apps/web/.env.local
#
# Production checklist:
#   1. Replace all placeholder values (your-project, change-me, eyJ...)
#   2. Set ENVIRONMENT=production, DEBUG=False
#   3. Create Supabase production project, update URLs + keys
#   4. Set up Google OAuth with production redirect URIs
#   5. Configure Sentry DSN for error monitoring
#   6. Set secure SECRET_KEY (64+ random chars)
#   7. Review CORS_ORIGINS for production domains
# =============================================================================

# ── Application ─────────────────────────────────────────────────────────────────
APP_NAME="Second Brain OS"
APP_VERSION=6.0.0
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
SECRET_KEY=change-me-in-production-64-chars-minimum
PRODUCTION_DOMAIN=secondbrain-os.vercel.app

# ── Supabase (Database + Auth) ─────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/{ref}/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=fake-jwt-token-string-for-testingInR5cCI6IkpXVCJ9...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=fake-jwt-token-string-for-testingInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=fake-jwt-token-string-for-testingInR5cCI6IkpXVCJ9...
SUPABASE_MAX_POOL_SIZE=10
SUPABASE_CONNECTION_TIMEOUT=30

# ── Authentication ─────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-from-supabase-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_MINUTES=43200
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# API Key Auth (for service-to-service communication)
API_KEY_ENABLED=False
API_KEY_STORAGE_HASH_ITERATIONS=600000

# ── AI Services ────────────────────────────────────────────────────────────────
# Primary: Ollama (local, free) — set USE_LOCAL_AI=True
# Fallback: Claude API (cloud, ~$0.015/request) — set CLAUDE_API_KEY
USE_LOCAL_AI=True
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_TIMEOUT=60
OLLAMA_MAX_RETRIES=3
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_TIMEOUT=60
CLAUDE_MAX_TOKENS=4096
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT=60

# ── AI Resilience ──────────────────────────────────────────────────────────────
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN=60
AI_MAX_RETRIES=3
AI_RETRY_BASE_DELAY=2
AI_FALLBACK_ORDER=ollama,claude,openai

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_CHAT_MAX=30
RATE_LIMIT_AUTOMATION_MAX=100

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@secondbrain.os
RESEND_REPLY_TO=support@secondbrain.os

# ── SMS (Twilio) — FUTURE ──────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Log Aggregation ────────────────────────────────────────────────────────────
# Logtail (Better Stack) — free tier: 1GB/month. Set token to enable.
LOGTAIL_SOURCE_TOKEN=
# Datadog — paid, full-featured observability
DD_API_KEY=
DD_SITE=datadoghq.com
# Service name tag for log records (default: secondbrain-api)
LOGGER_SERVICE_NAME=secondbrain-api

# ── Monitoring & Error Tracking ────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
POSTHOG_PERSONAL_API_KEY=

# ── Frontend-Specific (NEXT_PUBLIC_ prefix required) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=fake-jwt-token-string-for-testingInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ENVIRONMENT=development

# ── Scheduler Alerting ─────────────────────────────────────────────────────────
# Webhook URL for Slack/Discord/Generic alert delivery (cron job failure alerts)
ALERT_WEBHOOK_URL=
ALERT_SLACK_CHANNEL=#aria-alerts
ALERT_LOGTAIL_SOURCE_TOKEN=

# ── Feature Flags ──────────────────────────────────────────────────────────────
FEATURE_AI_CHAT_ENABLED=True
FEATURE_DAILY_BRIEFING_ENABLED=True
FEATURE_WEEKLY_REVIEW_ENABLED=True
FEATURE_OPPORTUNITY_RADAR_ENABLED=True
FEATURE_OFFLINE_MODE_ENABLED=False
FEATURE_NOTIFICATIONS_ENABLED=True

# Feature Flag Server Override — set FF_<KEY>=true/false to override any flag
# FF_NEW_DASHBOARD=true
# FF_CANARY_API_V2=false

# ── Canary Deployment ─────────────────────────────────────────────────────────
CANARY_ENABLED=False
CANARY_ROLLOUT_PERCENTAGE=0
CANARY_FLAG_KEY=
CANARY_MONITOR_INTERVAL_SECONDS=900

# ── Database (Direct — for migrations and seed scripts) ──────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/secondbrain
DATABASE_SCHEMA=public
DATABASE_SSL_MODE=prefer

# ── Redis (Cache & Queue) — FUTURE ────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_CACHE_TTL=300
# REDIS_QUEUE_NAME=secondbrain-queue

# ── Storage (S3-compatible) — FUTURE ──────────────────────────────────────────
# STORAGE_BUCKET=secondbrain-assets
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_ENDPOINT=https://s3.amazonaws.com

# ── PWA (Service Worker) ──────────────────────────────────────────────────────
NEXT_PUBLIC_PWA_ENABLED=True
PWA_CACHE_STRATEGY=network-first

# ── SOC 2 / Security (evidence collection) ────────────────────────────────────
AUDIT_LOG_ENABLED=True
AUDIT_LOG_RETENTION_DAYS=365
CSRF_PROTECTION_ENABLED=True
XSS_SANITIZATION_ENABLED=True
